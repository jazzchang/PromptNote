{
  "manifest_version": 3,
  "name": "咒语便签 - PromptNote",
  "version": "1.2.8",
  "description": "PromptNote · 将即梦AI作品一键保存到Eagle，自动提取提示词并添加到注释",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://jimeng.jianying.com/*",
    "http://localhost:41595/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "即梦 → Eagle"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jimeng.jianying.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "https://jimeng.jianying.com/*"
      ]
    }
  ]
}